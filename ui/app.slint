import {
    ListView,
    CheckBox,
    TextEdit,
    LineEdit,
    SpinBox,
    ComboBox,
    ScrollView,
    ProgressIndicator,
    Palette,
} from "std-widgets.slint";

// ==========================================
// GLOBALS & STRUCTS
// ==========================================

export struct DirectoryItem {
    name: string,
    path: string,
    depth: int,
    status: int, // 0: Normal, 1: Empty, 2: Deleted, 3: Protected, 4: Failed
    has_children: bool,
    is_expanded: bool,
    id: int,
    is_root: bool,
    tree_prefix: string,
    tree_lines: [int],
    is_hidden: bool,
    is_symlink: bool,
}

export global AppTheme {
    out property <color> bg-main: #1e1e1e;
    out property <color> bg-panel: #252526;
    out property <color> bg-hover: #2d2d30;
    out property <color> border: #3e3e42;

    out property <color> text-normal: #D4D4D4;
    out property <color> text-muted: #858585;

    out property <color> status-empty: #FF5555;
    out property <color> status-deleted: #55FF55;
    out property <color> status-protected: #55A0FF;
    out property <color> status-failed: #FFB86C;

    out property <color> folder-normal: #E0A96D;

    out property <color> primary: #0e639c;
    out property <color> danger: #e04545;
    out property <color> btn-dark: #3a3a3a;
    out property <color> btn-grey: #444444;
}

export global AppState {
    // Navigation
    in-out property <int> active_tab: 0;

    // Data & State
    in-out property <string> selected_folder: "";
    in-out property <string> log_text: "";
    in-out property <string> status_msg: "Ready.";
    in-out property <[DirectoryItem]> directories: [];
    in-out property <bool> is_scanning: false;
    in-out property <bool> is_deleting: false;
    in-out property <float> progress: 0.0;

    // Context Menu Triggers
    in-out property <int> selected_context_item_id: -1;
    in-out property <string> selected_context_item_path: "";

    // Counts
    in-out property <int> empty_count: 0;
    in-out property <int> deleted_count: 0;
    in-out property <int> failed_count: 0;

    // Settings
    in-out property <bool> consider_empty_files_empty: true;
    in-out property <bool> ignore_hidden: true;
    in-out property <bool> ignore_errors: true;
    in-out property <bool> hide_search_errors: true;
    in-out property <bool> skip_system: true;
    in-out property <int> delete_mode: 0;
    in-out property <int> max_depth: -1;
    in-out property <int> min_age_hours: 0;
    in-out property <int> pause_ms: 0;
    in-out property <bool> dry_run: false;

    // Strings & OS Integration
    in-out property <string> ignore_list_text: "";
    in-out property <string> ignore_files_text: "";
    in-out property <bool> is_integrated: false;
    in-out property <bool> auto_save_logs: false;
    in-out property <bool> mft_scan: false;
    in-out property <bool> is_admin: false;

    // Logic Callbacks
    callback browse_folder() -> string;
    callback search_folders();
    callback delete_folders();
    callback cancel_operation();
    callback exit_app();
    callback toggle_expand(int);
    callback reset_defaults();

    callback open_in_explorer(string);
    callback add_to_exclusions(int);

    callback toggle_context_menu(bool);
    callback toggle_auto_save_logs(bool);

    callback export_log();
    callback open_logs_folder();
}

// ==========================================
// ICONS
// ==========================================

component FolderIcon {
    in property <color> fill-color: AppTheme.folder-normal;
    width: 16px;
    height: 16px;
    Path {
        width: 100%;
        height: 100%;
        commands: "M 1 3 L 5 3 L 7 5 L 15 5 L 15 14 L 1 14 Z";
        fill: fill-color;
    }
}

component HomeIcon {
    in property <color> fill-color: AppTheme.folder-normal;
    width: 16px;
    height: 16px;
    Path {
        width: 100%;
        height: 100%;
        commands: "M 8 1 L 1 7 L 3 7 L 3 15 L 6 15 L 6 10 L 10 10 L 10 15 L 13 15 L 13 7 L 15 7 Z";
        fill: fill-color;
    }
}

component DeletedIcon {
    width: 16px;
    height: 16px;
    Path {
        width: 100%;
        height: 100%;
        commands: "M 2 8 L 6 12 L 14 3";
        stroke: AppTheme.status-deleted;
        stroke-width: 2px;
    }
}

component ProtectedIcon {
    width: 16px;
    height: 16px;
    Rectangle {
        x: 3px;
        y: 7px;
        width: 10px;
        height: 8px;
        background: AppTheme.status-protected;
        border-radius: 1px;
        Rectangle {
            x: 2px;
            y: -5px;
            width: 6px;
            height: 6px;
            border-color: AppTheme.status-protected;
            border-width: 1.5px;
            border-radius: 3px;
        }
    }
}

component FailedIcon {
    width: 16px;
    height: 16px;
    Path {
        width: 100%;
        height: 100%;
        commands: "M 8 1 L 16 15 L 0 15 Z";
        fill: AppTheme.status-failed;
    }

    Rectangle {
        x: 7.5px;
        y: 5px;
        width: 1px;
        height: 5px;
        background: #FFFFFF;
    }

    Rectangle {
        x: 7.5px;
        y: 11px;
        width: 1px;
        height: 1px;
        background: #FFFFFF;
    }
}

component NeverEmptyFolderIcon {
    in property <color> fill-color: AppTheme.folder-normal;
    width: 16px;
    height: 16px;
    Rectangle {
        width: 100%;
        height: 100%;
        FolderIcon {
            fill-color: fill-color;
        }

        Rectangle {
            x: 10px;
            y: 10px;
            width: 6px;
            height: 6px;
            background: AppTheme.bg-main;
            border-radius: 3px;
            Rectangle {
                x: 1px;
                y: 2.5px;
                width: 4px;
                height: 1px;
                background: AppTheme.status-empty;
            }
        }
    }
}

component ExpandCollapseIcon {
    in property <bool> is_expanded;
    width: 11px;
    height: 11px;
    Rectangle {
        width: 100%;
        height: 100%;
        border-color: #666666;
        border-width: 1px;
        background: AppTheme.bg-hover;
        border-radius: 1px;
        Rectangle {
            x: 2px;
            y: 5px;
            width: 7px;
            height: 1px;
            background: AppTheme.text-normal;
        }

        if !root.is_expanded: Rectangle {
            x: 5px;
            y: 2px;
            width: 1px;
            height: 7px;
            background: AppTheme.text-normal;
        }
    }
}

// ==========================================
// UI COMPONENTS
// ==========================================

component TabButton {
    in property <string> text;
    in property <bool> active;
    callback clicked;
    width: 90px;
    height: 28px;
    rect := Rectangle {
        background: active ? AppTheme.bg-hover : AppTheme.bg-main;
        border-color: active ? AppTheme.border : AppTheme.bg-panel;
        border-width: 1px;
        border-radius: 4px;
        animate background { duration: 150ms; }

        txt := Text {
            text: root.text;
            color: active ? #ffffff : AppTheme.text-muted;
            font-size: 12px;
            font-weight: active ? 600 : 400;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    states [
        hover when ta.has-hover && !active: {
            rect.background: AppTheme.bg-panel;
            txt.color: #cccccc;
        }
    ]
}

component CustomButton {
    in property <string> text;
    in property <bool> enabled: true;
    in property <color> primary-color: AppTheme.primary;
    callback clicked;
    height: 30px;
    min-width: 90px;

    rect := Rectangle {
        background: !enabled ? AppTheme.bg-hover : primary-color;
        border-radius: 4px;
        border-width: 1px;
        border-color: !enabled ? AppTheme.border : primary-color;
        opacity: !enabled ? 0.5 : 1.0;
        animate background { duration: 120ms; }

        // Dynamic width adjustment based on text + padding
        HorizontalLayout {
            padding-left: 16px;
            padding-right: 16px;
            alignment: center;

            Text {
                text: root.text;
                color: !enabled ? #666666 : #ffffff;
                font-size: 12px;
                font-weight: 500;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    states [
        hover when ta.has-hover && enabled: {
            rect.background: primary-color.brighter(15%);
        }
        active when ta.pressed && enabled: {
            rect.background: primary-color.darker(15%);
        }
    ]
}

// ==========================================
// MICRO-COMPONENTS
// ==========================================

// DRY component for Legends
component LegendRow {
    in property <string> label;
    in property <color> label-color: AppTheme.text-normal;

    HorizontalLayout {
        spacing: 8px;
        height: 18px;
        Rectangle {
            width: 16px;
            height: 16px;
            @children
        }

        Text {
            text: root.label;
            color: root.label-color;
            vertical-alignment: center;
        }
    }
}

component LegendPanel inherits Rectangle {
    width: 210px;
    border-color: AppTheme.border;
    border-width: 1px;
    background: AppTheme.bg-hover;
    border-radius: 4px;

    VerticalLayout {
        padding: 12px;
        spacing: 8px;
        Text {
            text: "Icon Meanings";
            font-weight: 700;
            color: #FFFFFF;
            font-size: 13px;
        }

        LegendRow {
            label: "Root";
            HomeIcon { }
        }

        LegendRow {
            label: "Hidden (Semi-transp.)";
            label-color: #A9A9A9;
            FolderIcon {
                opacity: 0.5;
            }
        }

        LegendRow {
            label: "Symlink / Junction";
            label-color: #A9A9A9;
            FolderIcon { }

            Path {
                width: 7px;
                height: 7px;
                x: 1px;
                y: 9px;
                commands: "M 1 6 L 6 1 L 3 1 M 6 1 L 6 4";
                stroke: #ffffff;
                stroke-width: 1.2px;
            }
        }

        LegendRow {
            label: "Never Empty";
            NeverEmptyFolderIcon { }
        }

        LegendRow {
            label: "Protected";
            label-color: AppTheme.status-protected;
            ProtectedIcon { }
        }

        LegendRow {
            label: "Empty";
            label-color: AppTheme.status-empty;
            FolderIcon {
                fill-color: AppTheme.status-empty;
            }
        }

        LegendRow {
            label: "Deleted";
            label-color: AppTheme.status-deleted;
            DeletedIcon { }
        }

        LegendRow {
            label: "Failed";
            label-color: AppTheme.status-failed;
            FailedIcon { }
        }

        Rectangle { } // Spacer

        LegendRow {
            label: "Will not be touched";
            label-color: AppTheme.text-normal;
            Rectangle {
                width: 12px;
                height: 12px;
                background: AppTheme.text-normal;
                border-radius: 2px;
                y: 2px;
            }
        }

        LegendRow {
            label: "Will be deleted";
            label-color: AppTheme.text-normal;
            Rectangle {
                width: 12px;
                height: 12px;
                background: AppTheme.status-empty;
                border-radius: 2px;
                y: 2px;
            }
        }

        LegendRow {
            label: "Protected";
            label-color: AppTheme.text-normal;
            Rectangle {
                width: 12px;
                height: 12px;
                background: AppTheme.status-protected;
                border-radius: 2px;
                y: 2px;
            }
        }
    }
}

component DirectoryTreeRow inherits Rectangle {
    in property <DirectoryItem> item;
    callback right-clicked(length, length, int, string);

    height: 28px;
    background: row-ta.has-hover ? AppTheme.bg-hover : AppTheme.bg-main;
    border-radius: 2px;
    animate background { duration: 100ms; }

    row-ta := TouchArea {
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.right) {
                root.right-clicked(self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y, item.id, item.path);
            }
        }
        double-clicked => {
            if (item.has_children && !AppState.is_scanning && !AppState.is_deleting) {
                AppState.toggle_expand(item.id);
            }
        }
    }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 8px;
        alignment: start;
        for line in item.tree_lines: Rectangle {
            width: 20px;
            height: 28px;
            if line == 1 || line == 2: Rectangle {
                x: parent.width / 2;
                y: 0px;
                width: 1px;
                height: parent.height;
                background: #444444;
            }
            if line == 3: Rectangle {
                x: parent.width / 2;
                y: 0px;
                width: 1px;
                height: parent.height / 2;
                background: #444444;
            }
            if line == 2 || line == 3: Rectangle {
                x: parent.width / 2;
                y: parent.height / 2;
                width: parent.width / 2;
                height: 1px;
                background: #444444;
            }
        }

        Rectangle {
            width: 15px;
            if item.has_children: ExpandCollapseIcon {
                is_expanded: item.is_expanded;
                y: 8px;
            }
            TouchArea {
                clicked => { if (item.has_children && !AppState.is_scanning && !AppState.is_deleting) { AppState.toggle_expand(item.id); } }
            }
        }

        Rectangle {
            width: 16px;
            opacity: item.is_hidden ? 0.45 : 1.0;
            if item.is_root: HomeIcon {
                y: 6px;
            }
            if !item.is_root && item.status == 2: DeletedIcon {
                y: 6px;
            }
            if !item.is_root && item.status == 4: FailedIcon {
                y: 6px;
            }
            if !item.is_root && item.status == 3: ProtectedIcon {
                y: 6px;
            }
            if !item.is_root && item.status == 0: NeverEmptyFolderIcon {
                y: 6px;
                fill-color: AppTheme.text-normal;
            }
            if !item.is_root && item.status == 1: FolderIcon {
                y: 6px;
                fill-color: AppTheme.status-empty;
            }
            if !item.is_root && item.is_symlink: Path {
                width: 7px;
                height: 7px;
                x: 1px;
                y: 9px;
                commands: "M 1 6 L 6 1 L 3 1 M 6 1 L 6 4";
                stroke: #ffffff;
                stroke-width: 1.2px;
            }
        }

        Text {
            text: item.name;
            color: item.status == 1 ? AppTheme.status-empty : (item.status == 2 ? AppTheme.status-deleted : (item.status == 3 ? AppTheme.status-protected : (item.status == 4 ? AppTheme.status-failed : AppTheme.text-normal)));
            vertical-alignment: center;
            font-size: 12px;
        }
    }
}

component EmptyState inherits Rectangle {
    background: #1a1a1c;
    border-radius: 4px;
    VerticalLayout {
        alignment: center;
        spacing: 12px;
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 48px;
                height: 48px;
                opacity: 0.3;
                Path {
                    width: 100%;
                    height: 100%;
                    commands: "M 4 8 L 16 8 L 22 14 L 44 14 L 44 40 L 4 40 Z";
                    fill: #858585;
                }

                Path {
                    width: 100%;
                    height: 100%;
                    commands: "M 24 18 L 24 30 M 19 25 L 24 30 L 29 25";
                    stroke: #ffffff;
                    stroke-width: 3px;
                }
            }
        }

        Text {
            text: "No Directory Scanned";
            horizontal-alignment: center;
            color: #ffffff;
            font-size: 14px;
            font-weight: 600;
            opacity: 0.7;
        }

        Text {
            text: "Drag & Drop a folder here\nor use the browse button to select a directory";
            horizontal-alignment: center;
            color: AppTheme.text-muted;
            font-size: 11px;
            opacity: 0.8;
        }
    }
}


// ==========================================
// TABS
// ==========================================

component FindTab inherits VerticalLayout {
    padding: 16px;
    spacing: 12px;
    callback show-context-menu(length, length, int, string);

    Text {
        text: "Please choose a directory to check:";
        font-size: 13px;
        font-weight: 500;
    }

    HorizontalLayout {
        spacing: 8px;
        height: 30px;
        LineEdit {
            text <=> AppState.selected_folder;
            vertical-stretch: 1;
        }

        CustomButton {
            text: "Browse...";
            primary-color: AppTheme.btn-dark;
            clicked => { AppState.selected_folder = AppState.browse_folder(); }
        }
    }

    HorizontalLayout {
        spacing: 12px;
        vertical-stretch: 1;
        Rectangle {
            border-color: AppTheme.border;
            border-width: 1px;
            border-radius: 4px;
            horizontal-stretch: 1;
            background: AppTheme.bg-main;

            if AppState.directories.length > 0 || AppState.is_scanning: ListView {
                for item in AppState.directories: DirectoryTreeRow {
                    item: item;
                    right-clicked(x, y, id, path) => { root.show-context-menu(x, y, id, path); }
                }
            }
            if AppState.directories.length == 0 && !AppState.is_scanning: EmptyState { }
        }

        LegendPanel { }
    }

    HorizontalLayout {
        spacing: 16px;
        height: 20px;
        Text {
            text: "Total found: " + AppState.directories.length;
            vertical-alignment: center;
            font-size: 12px;
        }

        Text {
            text: "Empty/Deletable: " + AppState.empty_count;
            vertical-alignment: center;
            color: AppTheme.status-empty;
            font-size: 12px;
        }

        Text {
            text: "Deleted: " + AppState.deleted_count;
            vertical-alignment: center;
            color: AppTheme.status-deleted;
            font-size: 12px;
        }

        Text {
            text: "Failed: " + AppState.failed_count;
            vertical-alignment: center;
            color: AppTheme.status-failed;
            font-size: 12px;
        }
    }

    HorizontalLayout {
        spacing: 12px;
        height: 20px;
        ProgressIndicator {
            progress: AppState.progress;
            indeterminate: AppState.is_scanning;
            width: 200px;
        }

        Text {
            text: AppState.status_msg;
            vertical-alignment: center;
            font-size: 12px;
        }
    }

    HorizontalLayout {
        spacing: 8px;
        height: 30px;
        CustomButton {
            text: "Search";
            clicked => { AppState.search_folders(); }
            enabled: !AppState.is_scanning && !AppState.is_deleting;
        }

        CustomButton {
            text: "Delete matches";
            clicked => { AppState.delete_folders(); }
            enabled: !AppState.is_scanning && !AppState.is_deleting && AppState.directories.length > 0;
            primary-color: AppTheme.danger;
        }

        CustomButton {
            text: "Cancel";
            clicked => { AppState.cancel_operation(); }
            enabled: AppState.is_scanning || AppState.is_deleting;
            primary-color: AppTheme.btn-grey;
        }

        CustomButton {
            text: "Show logs";
            clicked => { AppState.active_tab = 3; }
            primary-color: #333333;
        }

        Rectangle {
            horizontal-stretch: 1;
        }

        CustomButton {
            text: "Exit";
            clicked => { AppState.exit_app(); }
            primary-color: AppTheme.btn-dark;
        }
    }
}

component SettingsTab inherits ScrollView {
    VerticalLayout {
        padding: 20px;
        spacing: 20px;

        Text {
            text: "General Options";
            font-weight: 700;
        }

        CheckBox {
            text: "Directories with empty files will be considered empty";
            checked <=> AppState.consider_empty_files_empty;
        }

        CheckBox {
            text: "Ignore hidden directories";
            checked <=> AppState.ignore_hidden;
        }

        CheckBox {
            text: "Ignore errors during deletion";
            checked <=> AppState.ignore_errors;
        }

        CheckBox {
            text: "Hide search errors (like access denied errors)";
            checked <=> AppState.hide_search_errors;
        }

        CheckBox {
            text: "Skip system directories (recommended)";
            checked <=> AppState.skip_system;
        }

        Rectangle {
            height: 1px;
            background: AppTheme.border;
            vertical-stretch: 0;
        }

        Text {
            text: "OS Integration & Logs";
            font-weight: 700;
        }

        CheckBox {
            text: "Integrate into Windows Explorer Context Menu";
            checked <=> AppState.is_integrated;
            toggled => { AppState.toggle_context_menu(self.checked); }
        }

        CheckBox {
            text: "Auto-save logs to file (%APPDATA%\\REDR\\logs\\)";
            checked <=> AppState.auto_save_logs;
            toggled => { AppState.toggle_auto_save_logs(self.checked); }
        }

        CheckBox {
            text: "Direct MFT Scan (NTFS & Windows Administrator only)";
            checked <=> AppState.mft_scan;
            enabled: AppState.is_admin;
        }

        Rectangle {
            height: 1px;
            background: AppTheme.border;
            vertical-stretch: 0;
        }

        Text {
            text: "Limits & Performance";
            font-weight: 700;
        }

        HorizontalLayout {
            spacing: 20px;
            VerticalLayout {
                spacing: 10px;
                HorizontalLayout {
                    Text {
                        text: "Max directory nesting depth (-1 = infinite):";
                        vertical-alignment: center;
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                    }

                    SpinBox {
                        value <=> AppState.max_depth;
                        minimum: -1;
                        width: 100px;
                        height: 35px;
                    }
                }

                HorizontalLayout {
                    Text {
                        text: "Pause between each deletion in ms:";
                        vertical-alignment: center;
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                    }

                    SpinBox {
                        value <=> AppState.pause_ms;
                        minimum: 0;
                        width: 100px;
                        height: 35px;
                    }
                }
            }

            VerticalLayout {
                spacing: 10px;
                HorizontalLayout {
                    Text {
                        text: "Skip folders less than N hours old:";
                        vertical-alignment: center;
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                    }

                    SpinBox {
                        value <=> AppState.min_age_hours;
                        minimum: 0;
                        width: 100px;
                        height: 35px;
                    }
                }

                Rectangle { } // Spacer
            }
        }

        Rectangle {
            height: 1px;
            background: AppTheme.border;
            vertical-stretch: 0;
        }

        Text {
            text: "Delete Mode";
            font-weight: 700;
        }

        CheckBox {
            text: "Simulation Mode (Dry-run - safely preview deletions)";
            checked <=> AppState.dry_run;
        }

        Text {
            text: "How should empty directories be deleted?";
            color: AppState.dry_run ? AppTheme.text-muted : AppTheme.text-normal;
        }

        ComboBox {
            model: ["Delete to recycle bin and ignore errors (safer)", "Delete permanently"];
            current-index <=> AppState.delete_mode;
            height: 35px;
            enabled: !AppState.dry_run;
        }

        Rectangle {
            height: 1px;
            background: AppTheme.border;
            vertical-stretch: 0;
        }

        Text {
            text: "Reset Configuration";
            font-weight: 700;
        }

        Text {
            text: "Restore all settings and filters to their default startup values.";
        }

        HorizontalLayout {
            CustomButton {
                text: "Reset to Defaults";
                primary-color: #555555;
                clicked => { AppState.reset_defaults(); }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        Rectangle {
            vertical-stretch: 1;
        }
    }
}

component FiltersTab inherits HorizontalLayout {
    padding: 20px;
    spacing: 20px;
    VerticalLayout {
        spacing: 10px;
        horizontal-stretch: 1;
        Text {
            text: "Directories to Ignore (One per line):";
            font-weight: 700;
        }

        TextEdit {
            text <=> AppState.ignore_list_text;
            vertical-stretch: 1;
        }
    }

    VerticalLayout {
        spacing: 10px;
        horizontal-stretch: 1;
        Text {
            text: "Filenames to Ignore (One per line, e.g., *.tmp):";
            font-weight: 700;
        }

        TextEdit {
            text <=> AppState.ignore_files_text;
            vertical-stretch: 1;
        }
    }
}

component LogTab inherits VerticalLayout {
    padding: 15px;
    spacing: 10px;
    TextEdit {
        text <=> AppState.log_text;
        read-only: true;
        vertical-stretch: 1;
    }

    HorizontalLayout {
        spacing: 8px;
        height: 30px;
        CustomButton {
            text: "Export Log...";
            clicked => { AppState.export_log(); }
        }

        CustomButton {
            text: "Open Logs Folder";
            primary-color: AppTheme.btn-dark;
            clicked => { AppState.open_logs_folder(); }
        }

        Rectangle {
            horizontal-stretch: 1;
        }
    }
}

// ==========================================
// MAIN APP WINDOW ROUTER
// ==========================================

export component AppWindow inherits Window {
    title: "REDR - Da Red 'Unz Go Fasta!";
    icon: @image-url("../assets/icon.png");
    min-width: 850px;
    min-height: 650px;
    background: AppTheme.bg-main;

    init => { Palette.color-scheme = ColorScheme.dark; }

    property <length> cm_x;
    property <length> cm_y;

    context_menu := PopupWindow {
        x: root.cm_x;
        y: root.cm_y;
        width: 180px;
        height: 56px;
        close-policy: close-on-click;

        Rectangle {
            background: AppTheme.bg-panel;
            border-color: AppTheme.border;
            border-width: 1px;
            border-radius: 4px;
            VerticalLayout {
                padding: 4px;
                spacing: 2px;
                Rectangle {
                    height: 22px;
                    background: exc-ta.has-hover ? AppTheme.primary : transparent;
                    border-radius: 2px;
                    exc-ta := TouchArea {
                        clicked => { context_menu.close(); AppState.add_to_exclusions(AppState.selected_context_item_id); }
                    }

                    HorizontalLayout {
                        padding-left: 8px;
                        spacing: 8px;
                        alignment: start;
                        Rectangle {
                            width: 16px;
                            height: 16px;
                            ProtectedIcon { }
                        }

                        Text {
                            text: "Add to Exclusions";
                            color: #ffffff;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }
                }

                Rectangle {
                    height: 22px;
                    background: op-ta.has-hover ? AppTheme.primary : transparent;
                    border-radius: 2px;
                    op-ta := TouchArea {
                        clicked => { context_menu.close(); AppState.open_in_explorer(AppState.selected_context_item_path); }
                    }

                    HorizontalLayout {
                        padding-left: 8px;
                        spacing: 8px;
                        alignment: start;
                        Rectangle {
                            width: 16px;
                            height: 16px;
                            FolderIcon {
                                fill-color: #858585;
                            }
                        }

                        Text {
                            text: "Open in File Explorer";
                            color: #ffffff;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }
                }
            }
        }
    }

    VerticalLayout {
        padding: 16px;
        spacing: 12px;

        // Navigation Header
        HorizontalLayout {
            spacing: 4px;
            alignment: start;
            height: 32px;
            TabButton {
                text: "Find";
                active: AppState.active_tab == 0;
                clicked => { AppState.active_tab = 0; }
            }

            TabButton {
                text: "Settings";
                active: AppState.active_tab == 1;
                clicked => { AppState.active_tab = 1; }
            }

            TabButton {
                text: "Filters";
                active: AppState.active_tab == 2;
                clicked => { AppState.active_tab = 2; }
            }

            TabButton {
                text: "Log";
                active: AppState.active_tab == 3;
                clicked => { AppState.active_tab = 3; }
            }
        }

        // Active Tab Viewport
        Rectangle {
            background: AppTheme.bg-panel;
            border-color: AppTheme.border;
            border-width: 1px;
            border-radius: 6px;
            vertical-stretch: 1;

            if AppState.active_tab == 0: FindTab {
                show-context-menu(x, y, id, path) => {
                    AppState.selected_context_item_id = id;
                    AppState.selected_context_item_path = path;
                    root.cm_x = x;
                    root.cm_y = y;
                    context_menu.show();
                }
            }
            if AppState.active_tab == 1: SettingsTab { }
            if AppState.active_tab == 2: FiltersTab { }
            if AppState.active_tab == 3: LogTab { }
        }
    }
}
